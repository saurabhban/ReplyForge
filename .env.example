# ReplyForge Environment Variables
# Copy to .env and fill in your values

# ─── STRIPE ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
STRIPE_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID      # $29/mo recurring
STRIPE_TEAM_PRICE_ID=price_YOUR_TEAM_PRICE_ID    # $79/mo recurring

# ─── SUPABASE ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY        # Server-side only, never expose
SUPABASE_ANON_KEY=YOUR_ANON_KEY                   # Safe for frontend

# ─── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY       # From console.anthropic.com
# Alternative free option: OpenRouter (free models available)
# OPENROUTER_API_KEY=sk-or-YOUR_KEY

# ─── EMAIL ───────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_KEY                 # Free: 3,000 emails/mo

# ─── APP ─────────────────────────────────────────────────────
FRONTEND_URL=https://replyforge.vercel.app
PORT=3001
NODE_ENV=production
